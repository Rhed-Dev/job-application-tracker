# Copy to .env and fill in. Defaults below match docker-compose.yml.

# PostgreSQL connection string used by Prisma (docker compose exposes this locally)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobtrail"

# Secret for signing JWT access tokens — generate one: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string"

# Redis connection string used by BullMQ for delayed reminder jobs
REDIS_URL="redis://localhost:6379"

# Resend API key for transactional email (leave unset to print emails to stdout)
RESEND_API_KEY=""

# From address for reminder emails (must be a verified Resend domain in production)
EMAIL_FROM="JobTrail <onboarding@resend.dev>"

# Google OAuth client id from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""

# Google OAuth client secret (the matching credential's secret)
GOOGLE_CLIENT_SECRET=""

# Public base URL of the app — used for OAuth redirect URIs and email links
APP_URL="http://localhost:3000"
