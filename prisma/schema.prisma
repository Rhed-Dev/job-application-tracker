// Prisma schema for JobTrail — Job Application Tracker
//
// Run `npx prisma migrate dev` (with Postgres up via `docker compose up -d`)
// to create the database, then `npx prisma db seed` for demo data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  GHOSTED
}

enum ApplicationSource {
  LINKEDIN
  REFERRAL
  COMPANY_SITE
  JOB_BOARD
  RECRUITER
  OTHER
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  /// Null for OAuth-only accounts (e.g. signed up with Google).
  passwordHash  String?
  role          Role           @default(USER)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  applications  Application[]
  refreshTokens RefreshToken[]
}

/// Links a user to an external OAuth identity (currently Google).
model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Application {
  id             String            @id @default(cuid())
  userId         String
  company        String
  roleTitle      String
  location       String?
  source         ApplicationSource @default(OTHER)
  url            String?
  notes          String?
  /// Annual salary range in USD.
  salaryMin      Int?
  salaryMax      Int?
  status         ApplicationStatus @default(SAVED)
  /// Current interview round; 0 until the application reaches INTERVIEWING.
  interviewRound Int               @default(0)
  appliedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusEvents   StatusEvent[]
  reminders      Reminder[]

  @@index([userId, status])
  @@index([userId, updatedAt])
}

/// Append-only log of every status transition (event sourcing-lite).
/// Powers the timeline view and all funnel / days-in-stage analytics.
model StatusEvent {
  id            String             @id @default(cuid())
  applicationId String
  /// Null for the initial event created with the application.
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  at            DateTime           @default(now())
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, at])
}

model Reminder {
  id            String      @id @default(cuid())
  applicationId String
  remindAt      DateTime
  note          String?
  sent          Boolean     @default(false)
  sentAt        DateTime?
  /// BullMQ job id (deterministic: "reminder:<id>") so jobs can be
  /// de-duplicated and removed when a reminder is deleted.
  jobId         String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([sent, remindAt])
}

/// Opaque refresh tokens, stored hashed (SHA-256). Rotation chain is kept
/// via replacedById; a revoked token presented again means reuse → the whole
/// user session family is revoked.
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
